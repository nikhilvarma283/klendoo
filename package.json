{
  "name": "klendoo",
  "version": "0.1.0",
  "description": "Micropayment-driven scheduling platform on Algorand x402",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "db:push": "turbo run db:push --filter=packages-db",
    "db:studio": "turbo run db:studio --filter=packages-db",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
